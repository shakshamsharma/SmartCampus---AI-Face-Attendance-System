# SmartCampus AI - Environment Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════
ENVIRONMENT=development
DEBUG=False
APP_NAME=SmartCampus AI
APP_VERSION=3.0.0

# ═══════════════════════════════════════════════════════════════════════════
# SECURITY - CRITICAL: CHANGE THESE IN PRODUCTION!
# ═══════════════════════════════════════════════════════════════════════════
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_RANDOM_SECRET_KEY_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════
# Development (SQLite)
DATABASE_URL=sqlite:///./smartcampus.db

# Production (PostgreSQL) - Uncomment and configure for production
# DATABASE_URL=postgresql://user:password@localhost:5432/smartcampus
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ═══════════════════════════════════════════════════════════════════════════
# REDIS (Optional - for caching and session management)
# ═══════════════════════════════════════════════════════════════════════════
REDIS_ENABLED=False
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════════════════
# CORS - CRITICAL: Restrict in production!
# ═══════════════════════════════════════════════════════════════════════════
# Development
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:8000

# Production - Set to your actual frontend URL
# ALLOWED_ORIGINS=https://yourdomain.com

# ═══════════════════════════════════════════════════════════════════════════
# FILE UPLOAD
# ═══════════════════════════════════════════════════════════════════════════
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg

# ═══════════════════════════════════════════════════════════════════════════
# FACE RECOGNITION
# ═══════════════════════════════════════════════════════════════════════════
FACE_RECOGNITION_THRESHOLD=60
MIN_CONFIDENCE_SCORE=40
UNKNOWN_FACE_THRESHOLD=75
FACE_DATA_DIR=face_data

# ═══════════════════════════════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════════════════════════════
RATE_LIMIT_PER_MINUTE=60
LOGIN_RATE_LIMIT_PER_MINUTE=5

# ═══════════════════════════════════════════════════════════════════════════
# AI ASSISTANT (OpenAI)
# ═══════════════════════════════════════════════════════════════════════════
OPENAI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4-turbo-preview
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1000

# ═══════════════════════════════════════════════════════════════════════════
# MONITORING & LOGGING
# ═══════════════════════════════════════════════════════════════════════════
SENTRY_ENABLED=False
SENTRY_DSN=your_sentry_dsn_here
LOG_LEVEL=INFO
LOG_FORMAT=json

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════════════════
SMTP_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@smartcampus.ai
SMTP_USE_TLS=True

# ═══════════════════════════════════════════════════════════════════════════
# SESSION & SECURITY
# ═══════════════════════════════════════════════════════════════════════════
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=True

# ═══════════════════════════════════════════════════════════════════════════
# PAGINATION
# ═══════════════════════════════════════════════════════════════════════════
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ═══════════════════════════════════════════════════════════════════════════
# BACKUP & RECOVERY
# ═══════════════════════════════════════════════════════════════════════════
BACKUP_ENABLED=False
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
